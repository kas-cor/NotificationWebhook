<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark theme colors -->
    <style name="Theme.NotifWebhook" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand -->
        <item name="colorPrimary">@color/md_theme_primary_dark</item>
        <item name="colorOnPrimary">@color/md_theme_on_primary_dark</item>
        <item name="colorPrimaryContainer">@color/md_theme_primary_container_dark</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_on_primary_container_dark</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/md_theme_secondary_dark</item>
        <item name="colorOnSecondary">@color/md_theme_on_secondary_dark</item>
        <item name="colorSecondaryContainer">@color/md_theme_secondary_container_dark</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_on_secondary_container_dark</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/md_theme_tertiary_dark</item>
        <item name="colorOnTertiary">@color/md_theme_on_tertiary_dark</item>

        <!-- Error -->
        <item name="colorError">@color/md_theme_error_dark</item>
        <item name="colorOnError">@color/md_theme_on_error_dark</item>

        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/md_theme_background_dark</item>
        <item name="colorOnBackground">@color/md_theme_on_background_dark</item>
        <item name="colorSurface">@color/md_theme_surface_dark</item>
        <item name="colorOnSurface">@color/md_theme_on_surface_dark</item>
        <item name="colorSurfaceVariant">@color/md_theme_surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_on_surface_variant_dark</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
